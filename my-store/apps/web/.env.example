VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key

# API base URL (used by getApiBase() in @/lib/api). Use HTTPS in production.
# Production: URL my-store apps/server (vd. https://api.mavrykpremium.store).
VITE_API_URL=http://localhost:4000
# Optional legacy fallback: VITE_SERVER_URL
#
# Trên server chạy apps/server bắt buộc đặt ADMIN_ORDERLIST_API_URL → backend admin_orderlist
# (cùng các route mà Vite proxy khi dev: tin tức, Renew Adobe public, /image/articles).

# Chỉ dùng bởi vite.config.ts (proxy dev): tin tức + Renew Adobe + ảnh bài → admin_orderlist
# VITE_ADMIN_API_URL=http://127.0.0.1:3001
# my-store apps/server (mặc định 4000)
# VITE_STORE_API_URL=http://127.0.0.1:4000

# (Tùy chọn) Nếu DB có image_url dạng https://admin.../image/... khi dev local — strip về /image/... để qua proxy
# VITE_ADMIN_PUBLIC_ORIGIN=https://admin.mavrykpremium.store

# Optional: Sentry Error Tracking
# Get your DSN from https://sentry.io after creating a project
# Format: https://[key]@[org].ingest.sentry.io/[project-id]
# VITE_SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
